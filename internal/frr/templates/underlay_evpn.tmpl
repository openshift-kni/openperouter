{{ define "underlayevpn"}}
{{- if .Underlay.EVPN.VTEP }}
  address-family ipv4 unicast
    network {{ .Underlay.EVPN.VTEP }}
  exit-address-family
{{ end }}
  address-family l2vpn evpn
{{- range .Underlay.Neighbors }}
    neighbor {{ .ID }} activate
{{- if isEBGP $.Underlay.MyASN .ASN }}
    neighbor {{ .ID }} allowas-in
{{- end }}
{{- end }}
    advertise-all-vni
    advertise-svi-ip
  exit-address-family
{{- end }}
